{
  "name": "ad-auditor",
  "displayName": "Ad Auditor",
  "version": "0.0.1",
  "description": "Visualizes the memory and DOM impact of ad banners by overlaying stats directly on iframes.",
  "author": "Jakub 'Kocmouch' Kamiński",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "bun test"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://creatives-preview.rtbhouse.com/*",
      "https://statics.creativecdn.com/*",
      "https://ams.creativecdn.com/*"
    ],
    "permissions": [
      "scripting",
      "tabs",
      "storage",
      "debugger"
    ]
  }
}
